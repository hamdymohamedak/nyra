fn main() {
    let thedate = date()
    print(thedate.year)
    print(thedate.month)
    print(thedate.day)
    print(thedate.hour)
    print(thedate.minute)
    print(thedate.second)
    print(thedate.week)
    print(thedate.millisecond)
    // JS-style aliases
    print(thedate.minutes)
    print(thedate.seconds)
    print(thedate.weekday)
}
